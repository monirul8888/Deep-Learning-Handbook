     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0.9\n"
     ]
    }
   ],
   "source": [
    "print(intercept_)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 39,
   "id": "06aaaf0b",
   "metadata": {},
   "outputs": [],
   "source": [
    "m = - (cofec[0]/cofec[1])\n",
    "b = -intercept_/cofec[1]\n",
    "\n",
    "x_input = np.linspace(-3, 3, 100)\n",
    "y_input = m*x_input + b"
   ]
