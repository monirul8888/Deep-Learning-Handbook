   "source": [
    "from sklearn.datasets import make_classification\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "cca4b19b",
   "metadata": {},
   "outputs": [],
   "source": [
    "X, y= make_classification(n_samples=100,\n",
    "                          n_features=2,\n",
    "                          n_informative=1,\n",
    "                          n_redundant=0,\n",
    "                          n_classes=2,\n",
    "                          n_clusters_per_class=1,\n",
    "                          random_state=41,\n",
    "                          hypercube=False,\n",
    "                          class_sep=10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 32,
   "id": "03e68cf9",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "582acfcd",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x700 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.figure(figsize=(10, 7))\n",
    "plt.scatter(\n",
    "    X[:, 0],      # First feature\n",
    "    X[:, 1],      # Second feature\n",
    "    c=y,          # Color points by class\n",
    "    cmap=\"winter\",\n",
    "    s=100\n",
    ")\n",
    "\n",
    "plt.xlabel(\"Feature 1\")\n",
    "plt.ylabel(\"Feature 2\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "id": "6098136f",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "\n",
    "def perceptron(X, y):\n",
    "\n",
    "    X = np.insert(X, 0, 1, axis=1)\n",
    "    weights = np.ones(X.shape[1])\n",
    "\n",
    "    lr = 0.1\n",
    "\n",
    "    for i in range(1000):\n",
    "\n",
    "        j = np.random.randint(0, 100)\n",
    "\n",
    "        y_hat = 1 if np.dot(X[j], weights) >= 0 else 0\n",
    "\n",
    "        weights = weights + lr * (y[j] - y_hat) * X[j]\n",
    "\n",
    "    return weights[0], weights[1:]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "745c714a",
   "metadata": {},
   "outputs": [],
   "source": [
    "np.random.seed(42)\n",
    "\n",
    "intercept_, cofec = perceptron(X,y)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "5e0a237f",
   "metadata": {},
   "outputs": [
    {
